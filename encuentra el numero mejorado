import random
numero = random.randint(1, 20)
contador = 0
while contador < 5:
    respuesta = int(input("adivina el numero"))
    if respuesta < numero:
        print("muy bajo")
    elif respuesta > numero:
        print("muy alto")
    elif respuesta == numero:
        print("numero correcto")
    contador += 1
print("intentalo denuevo")
    
